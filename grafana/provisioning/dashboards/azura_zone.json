{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Dashboard serre Azura — EC, pH, Température, Humidité, Radiation, Débit",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "EC & pH",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pH actuel" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "fixedColor": "#4d9de0", "mode": "fixed" } },
              { "id": "custom.axisLabel", "value": "pH" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "EC actuel" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d96f", "mode": "fixed" } },
              { "id": "custom.axisLabel", "value": "EC (mS/cm)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "EC programme" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d96f80", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT sr.timestamp AS time, sr.ec_actual AS \"EC actuel\", sr.ec_prog AS \"EC programme\", sr.ph_actual AS \"pH actuel\", sr.ph_prog AS \"pH programme\" FROM sensor_readings sr JOIN devices d ON d.id = sr.device_id WHERE d.farm_name = '$farm_name' AND d.house_number = '$house_number' AND sr.timestamp BETWEEN $__timeFrom() AND $__timeTo() ORDER BY sr.timestamp ASC",
          "refId": "A"
        },
        {
          "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "hide": false,
          "rawSql": "SELECT\n  sr.timestamp AS time,\n  sr.ph_actual AS \"pH actuel\",\n  sr.ph_prog   AS \"pH programme\"\nFROM sensor_readings sr\nJOIN devices d ON d.id = sr.device_id\nWHERE d.farm_name    = '$farm_name'\n  AND d.house_number = '$house_number'\n  AND sr.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY sr.timestamp ASC",
          "refId": "B"
        }
      ]
    },

    {
      "id": 2,
      "title": "Température & Humidité",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Température (°C)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#f5a623", "mode": "fixed" } },
              { "id": "custom.axisLabel", "value": "Température (°C)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Humidité (%)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#4d9de0", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Humidité (%)" },
              { "id": "unit", "value": "percent" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT\n  sr.timestamp  AS time,\n  sr.avg_temp   AS \"Température (°C)\",\n  COALESCE(sr.humidity, 0)   AS \"Humidité (%)\"\nFROM sensor_readings sr\nJOIN devices d ON d.id = sr.device_id\nWHERE d.farm_name    = '$farm_name'\n  AND d.house_number = '$house_number'\n  AND sr.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY sr.timestamp ASC",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Radiation solaire",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "watt"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Radiation (W/m²)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#f5e642", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cumul (J/cm²)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#f5a623", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT\n  sr.timestamp          AS time,\n  sr.radiation          AS \"Radiation (W/m²)\",\n  COALESCE(sr.radiation_sum, 0) AS \"Cumul journalier (J/cm²)\"\nFROM sensor_readings sr\nJOIN devices d ON d.id = sr.device_id\nWHERE d.farm_name    = '$farm_name'\n  AND d.house_number = '$house_number'\n  AND sr.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY sr.timestamp ASC",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Débit & Irrigation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "barAlignment": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Débit (L/h)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d96f", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Débit nominal (L/h)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d96f40", "mode": "fixed" } },
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineStyle", "value": { "dash": [6, 6], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["last", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "azura_timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT\n  sr.timestamp   AS time,\n  sr.flow        AS \"Débit (L/h)\",\n    COALESCE(sr.flow_nominal, 0) AS \"Débit nominal (L/h)\"\nFROM sensor_readings sr\nJOIN devices d ON d.id = sr.device_id\nWHERE d.farm_name    = '$farm_name'\n  AND d.house_number = '$house_number'\n  AND sr.timestamp BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY sr.timestamp ASC",
          "refId": "A"
        }
      ]
    }

  ],

